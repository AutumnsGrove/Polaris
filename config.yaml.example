# Copy this to config.yaml and fill in secrets via environment variables
# (never commit real API keys — config.yaml is gitignored).

server:
  host: "127.0.0.1"   # bind to 0.0.0.0 (or the Tailscale IP) once deployed to the potato
  port: 8899

openrouter:
  api_key: "${OPENROUTER_API_KEY}"
  base_url: "https://openrouter.ai/api/v1"

searxng:
  base_url: "http://localhost:18888"   # local dev; point at http://100.81.103.51:8888 on the potato

foursquare:
  api_key: "${FOURSQUARE_API_KEY}"   # optional — nearby_search falls back to SearXNG without it. Free tier: 10k calls/month. https://foursquare.com/developers

# Geocoded when nearby_search omits a location. Optional — omit entirely
# to require an explicit location on every nearby_search call.
default_location: ""   # e.g. "Seattle, WA" or "47.6062, -122.3321"

# Push-to-talk transcription and read-aloud replies, both via OpenRouter
# (no local sidecar processes — this is a stateless web app, not a
# persistent companion process like her-go).
voice:
  stt_model: "mistralai/voxtral-mini-transcribe"
  stt_fallback_model: "openai/whisper-large-v3"   # tried once if the primary model times out/errors
  tts_model: "hexgrad/kokoro-82m"
  tts_voice: "bf_lily"   # British female "Lily" — see hexgrad/Kokoro-82M's VOICES.md for the full list
  tts_format: "mp3"      # OpenRouter's Kokoro endpoint only documents mp3/pcm

database:
  path: "./polaris.db"

logging:
  dir: "./logs"   # one file per day (YYYY-MM-DD.log), 90-day retention, pruned automatically

service:
  label: "polaris"

# Threshold (prompt + completion tokens) at which a thread auto-compacts:
# the model summarizes everything so far and future turns continue from
# that summary instead of the full raw history. Also the denominator for
# the context-usage % shown next to thread cost in the UI.
context_window_tokens: 100000

default_model: "mimo-pro"

# Each model pins a specific OpenRouter provider (not just a model slug).
# Different providers hosting the same model often have very different
# (or no) prompt-caching support/pricing — pinning keeps caching consistent.
# For the MiMo models specifically, pinning to "xiaomi/fp8" isn't just
# about caching: per OpenRouter's own endpoint list, it's the only host
# whose supported_parameters actually include "tools"/"tool_choice" —
# an unpinned request could silently land somewhere that can't call
# web_search/web_read/nearby_search at all.
models:
  - id: "mimo-pro"
    name: "MiMo v2.5 Pro"
    model: "xiaomi/mimo-v2.5-pro"
    provider: ["xiaomi/fp8"]
    temperature: 0.4
    max_tokens: 4096
    reasoning:
      enabled: true
      effort: "medium"   # low | medium | high — mutually exclusive with max_tokens
  - id: "mimo"
    name: "MiMo v2.5"
    model: "xiaomi/mimo-v2.5"
    provider: ["xiaomi/fp8"]
    temperature: 0.4
    max_tokens: 4096
    # Both models below reason internally before answering — without
    # requesting it explicitly, OpenRouter won't surface those tokens at
    # all, so the UI has no way to show what's actually happening.
    reasoning:
      enabled: true
      effort: "medium"   # low | medium | high — mutually exclusive with max_tokens
  - id: "deepseek"
    name: "DeepSeek V4 Flash"
    model: "deepseek/deepseek-v4-flash"
    provider: ["deepseek"]
    temperature: 0.4
    max_tokens: 4096
    reasoning:
      enabled: true
      effort: "medium"
